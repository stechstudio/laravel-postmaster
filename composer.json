{
    "name": "stechstudio/laravel-postmaster",
    "description": "Verify, normalize, and track email delivery webhooks from SendGrid, Postmark, Mailgun, Amazon SES, and Resend",
    "license": "MIT",
    "authors": [
        {
            "name": "Joseph Szobody",
            "email": "joseph@stechstudio.com",
            "homepage": "https://stechstudio.com"
        }
    ],
    "homepage": "https://github.com/stechstudio/laravel-postmaster",
    "keywords": [
        "Laravel",
        "Postmaster",
        "Email",
        "Email Events",
        "Webhooks",
        "SendGrid",
        "Postmark",
        "Mailgun",
        "SES",
        "Resend"
    ],
    "replace": {
        "stechstudio/laravel-email-events": "self.version"
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "laravel/prompts": "^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0|^13.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0|^11.0",
        "larastan/larastan": "^3.0"
    },
    "suggest": {
        "sendgrid/sendgrid":    "Required to sync SendGrid's suppression list (postmaster:sync).",
        "wildbit/postmark-php": "Required to sync Postmark's suppression list.",
        "mailgun/mailgun-php":  "Required to sync Mailgun's suppression list.",
        "aws/aws-sdk-php":      "Required to sync Amazon SES's suppression list."
    },
    "autoload": {
        "psr-4": {
            "STS\\Postmaster\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "STS\\Postmaster\\Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "STS\\Postmaster\\PostmasterServiceProvider"
            ],
            "aliases": {
                "Postmaster": "STS\\Postmaster\\Facades\\Postmaster"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ]
    }
}